# Optional. When absent, the API uses deterministic demo candidates.
GOOGLE_MAPS_API_KEY=

# Optional browser-restricted key for the live interactive map.
# Restrict this key to Maps JavaScript API + your local/deployed HTTP referrers.
VITE_GOOGLE_MAPS_BROWSER_KEY=
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Optional frontend override when the API is not on localhost:8000.
VITE_API_URL=http://localhost:8000
