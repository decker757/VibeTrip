# Optional. When absent, the API uses deterministic demo candidates.
GOOGLE_MAPS_API_KEY=
# Explicit opt-in switch. Keep false while testing the UI to prevent billable calls.
VIBETRIP_LIVE_MAPS_ENABLED=false
# Hard stop for live autocomplete requests per client per rolling minute.
VIBETRIP_AUTOCOMPLETE_MAX_PER_MINUTE=20
# Process-local circuit breakers for other billable Google calls.
VIBETRIP_GOOGLE_ROUTES_MAX_PER_MINUTE=10
VIBETRIP_GOOGLE_PLACES_MAX_PER_MINUTE=30
VIBETRIP_GOOGLE_DETAILS_MAX_PER_MINUTE=20

# Optional LLM recommendation layer. Without this, deterministic ranking remains active.
OPENAI_API_KEY=
VIBETRIP_LLM_ENABLED=true
VIBETRIP_LLM_SEARCH_ENABLED=true
VIBETRIP_LLM_SEARCH_MAX_PER_MINUTE=10
VIBETRIP_LLM_MODEL=gpt-4o-mini
VIBETRIP_LLM_TIMEOUT_SECONDS=12

# Optional browser-restricted key for the live interactive map.
# Restrict this key to Maps JavaScript API + your local/deployed HTTP referrers.
VITE_GOOGLE_MAPS_BROWSER_ENABLED=false
VITE_GOOGLE_MAPS_BROWSER_KEY=
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
DATABASE_URL=postgresql://vibetrip:vibetrip@localhost:5432/vibetrip

# Local auth for judging; set a random value outside demo mode.
VIBETRIP_AUTH_SECRET=vibetrip-local-development-secret

# Optional frontend override when the API is not on localhost:8000.
VITE_API_URL=http://localhost:8000
